{
  "workflowId": "schedule-demo",
  "version": 1,
  "defaults": {
    "retryPolicy": { "maxAttempts": 1, "backoff": "fixed", "baseMs": 1000 },
    "timeoutMs": 60000,
    "maxOutputBytes": 4096
  },
  "nodes": {
    "create-daily-task": {
      "type": "hostExecutor",
      "executor": "botmux-schedule",
      "input": {
        "name": "schedule-demo daily 9am",
        "schedule": "0 9 * * *",
        "parsed": {
          "kind": "cron",
          "expr": "0 9 * * *",
          "display": "0 9 * * *"
        },
        "prompt": "Schedule demo: run workflow self-check.",
        "workingDir": "/tmp/botmux-schedule-demo",
        "chatId": "oc_workflow_demo",
        "scope": "thread"
      }
    }
  }
}
